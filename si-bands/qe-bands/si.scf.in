&control
	calculation = 'scf'
	restart_mode = 'from_scratch'
	prefix = 'Si'
	verbosity = 'medium'
	outdir = './tmp/'
	pseudo_dir = '../../pseudo/'
/
&system
	ibrav=2, celldm(1)=10.2, nat=2, ntyp=1, ecutwfc=25.0
/
&electrons
	mixing_beta = 0.7
	conv_thr = 1.0e-8
	diagonalization = 'david'
/
ATOMIC_SPECIES
 Si 28.086 Si_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS {alat}
 Si 0.00 0.00 0.00
 Si 0.25 0.25 0.25
K_POINTS {automatic}
 4 4 4 0 0 0
