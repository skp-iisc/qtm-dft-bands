&control
	calculation = 'bands'
	prefix = 'Si'
	outdir = './tmp/'
	pseudo_dir = '../../pseudo/'
/
&system
	ibrav=2, celldm(1)=10.2, nat=2, ntyp=1, ecutwfc=25.0, nbnd=12
/
&electrons
	mixing_beta = 0.7
	conv_thr = 1.0e-7
	diagonalization = 'cg'
/
ATOMIC_SPECIES
 Si 28.086 Si_ONCV_PBE-1.2.upf
ATOMIC_POSITIONS {alat}
 Si 0.00 0.00 0.00
 Si 0.25 0.25 0.25
K_points {crystal_b}
5
0.000  0.500  0.000  50 ! L
0.000  0.000  0.000  50 ! GAMMA
-0.500  0.000  -0.500  50 ! X
-0.375  0.250  -0.375  50 ! K
0.000  0.000  0.000  0 ! GAMMA
